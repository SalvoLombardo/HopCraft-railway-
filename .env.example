# ================================
# DATABASE (PostgreSQL)
# ================================
DATABASE_URL=postgresql+asyncpg://hopcraft:password@db:5432/hopcraft
DB_PASSWORD=your_secure_password_here

# ================================
# REDIS
# ================================
REDIS_URL=redis://redis:6379/0

# ================================
# FLIGHT PROVIDERS — cascade SerpAPI → Amadeus → Apify
# ================================
#
# FLIGHT_PROVIDER — controlla l'ordine della cascade.
#   cascade  → automatico per quota residua Redis: SerpAPI → Amadeus → Apify (default)
#   serpapi  → SerpAPI in testa, Amadeus e Apify come fallback
#   amadeus  → Amadeus in testa, SerpAPI e Apify come fallback
#              consigliato in sviluppo: Amadeus ha 2000 req/mese vs 250 di SerpAPI
#   apify    → Apify in testa (solo per test, più lento)
FLIGHT_PROVIDER=cascade

# SerpAPI — Google Flights (250 req/mese gratis)
# Registrazione: https://serpapi.com — copre Wizz Air, easyJet (Ryanair parziale)
# Nessuna carta di credito richiesta.
SERPAPI_API_KEY=your_serpapi_api_key_here

# Amadeus Self-Service API (2.000 req/mese gratis)
# Registrazione: https://developers.amadeus.com/ — nessuna carta richiesta
# Nota: tier gratuito copre solo major carriers, NO low-cost EU.
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# Apify — Google Flights scraper (~$5 crediti/mese gratis, ~180 req)
# Include low-cost carriers (Ryanair, Wizz Air, easyJet) — fallback di ultima istanza.
# Registrazione: https://apify.com — nessuna carta richiesta.
# Actor ID: 1dYHRKkEBHBPd0JM7
# Lascia vuoto per disabilitare Apify dalla cascade.
APIFY_API_TOKEN=

# ================================
# LLM PROVIDER
# Opzioni: gemini | groq | mistral
# Con fallback automatico in quest'ordine se il primario fallisce
# Nessuno dei tre richiede carta di credito per il tier gratuito
# ================================
LLM_PROVIDER=gemini

# Google Gemini 2.5 Flash (primario)
# API key su: https://aistudio.google.com — generata istantaneamente, no carta
GEMINI_API_KEY=your_gemini_api_key_here

# Groq — Llama 3.3 70B (fallback veloce, >300 token/sec)
# Registrazione: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Mistral — La Plateforme (fallback volume, 1B token/mese gratis)
# Registrazione: https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# ================================
# APP
# ================================
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
CACHE_TTL_HOURS=6

# Cache TTL (hours) for AI-generated itinerary suggestions (Smart Multi-City step 2).
# Avoids re-calling the LLM for repeated searches with the same parameters.
LLM_CACHE_TTL_HOURS=24

MAX_AIRPORTS_SEARCH=300

# Per-IP hourly rate limits on the public search endpoints.
# Protect the limited monthly provider/LLM quotas from a single abusive client.
RATE_LIMIT_REVERSE_HOURLY=30
RATE_LIMIT_SMART_HOURLY=10
